# Set default behavior to handle line endings automatically.
* text=auto

# Force LF line endings for all shell scripts.
*.sh text eol=lf

# Explicitly set other text files to LF as well.
LICENSE text eol=lf
README.md text eol=lf
*.env text eol=lf
*.conf* text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.json text eol=lf
